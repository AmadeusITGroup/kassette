{
  "name": "@amadeus-it-group/kassette",
  "version": "1.7.0",
  "description": "Development server, used mainly for testing, which proxies requests and is able to easily manage local mocks.",
  "scripts": {
    "prepare": "husky install && npm run build && npm run apidoc",
    "lint": "eslint \"packages/**/*.ts\"",
    "format:check": "prettier --check .",
    "format:fix": "prettier --write .",
    "test": "npm run ut",
    "ut": "jest",
    "ut:watch": "jest --watch",
    "ut:coverage": "jest --coverage",
    "build": "rimraf ./dist ./build && rollup --failAfterWarnings -c ./packages/rollup.config.js && tsc -p ./packages/tsconfig.dts.json && api-extractor run --config ./packages/api-extractor.json --verbose",
    "build:coverage": "rimraf ./dist && rollup --failAfterWarnings -c ./packages/rollup.cov.config.js",
    "apidoc": "typedoc",
    "e2e": "npm run build && mocha packages/e2e/run.js",
    "e2e:coverage": "npm run build:coverage && nyc mocha packages/e2e/run.js"
  },
  "license": "MIT",
  "main": "dist/index.js",
  "bin": "./bin/index.js",
  "keywords": [
    "record",
    "replay",
    "test",
    "testing",
    "server",
    "mock",
    "mocking",
    "har",
    "http",
    "http2",
    "https",
    "proxy",
    "proxy-server",
    "http-proxy",
    "https-proxy",
    "man-in-the-middle",
    "mitm",
    "mock-server",
    "mocking-server",
    "local-mocks"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/AmadeusITGroup/kassette"
  },
  "engines": {
    "node": ">=10.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/plugin-syntax-decorators": "^7.24.0",
    "@babel/plugin-syntax-typescript": "^7.23.3",
    "@commitlint/cli": "^19.0.3",
    "@commitlint/config-conventional": "^19.0.3",
    "@microsoft/api-extractor": "^7.42.1",
    "@rollup/plugin-replace": "^5.0.5",
    "@rollup/plugin-typescript": "^11.1.6",
    "@types/jest": "^29.5.12",
    "@types/koa": "^2.15.0",
    "@types/koa-router": "^7.4.8",
    "@types/mime-types": "^2.1.4",
    "@types/node": "^20.11.24",
    "@types/node-forge": "^1.3.11",
    "@types/yargs": "^17.0.32",
    "@typescript-eslint/eslint-plugin": "^7.1.0",
    "@typescript-eslint/eslint-plugin-tslint": "^7.0.2",
    "@typescript-eslint/parser": "^7.1.0",
    "babel-plugin-istanbul": "^6.1.1",
    "chai": "^5.1.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "husky": "^9.0.11",
    "jest": "^29.7.0",
    "koa": "^2.15.0",
    "koa-router": "^12.0.1",
    "memfs": "^4.7.7",
    "mocha": "^10.3.0",
    "nyc": "^15.1.0",
    "playwright": "^1.42.0",
    "prettier": "^3.2.5",
    "rimraf": "^5.0.5",
    "rollup": "^4.12.0",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typedoc": "^0.25.9",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "date-fns": "^3.3.1",
    "http2-wrapper": "^2.2.1",
    "interpret": "^3.1.1",
    "istextorbinary": "^9.5.0",
    "mime-types": "^2.1.35",
    "node-forge": "^1.3.1",
    "picocolors": "^1.0.0",
    "rechoir": "^0.8.0",
    "yaml": "^2.4.0",
    "yargs": "^17.7.2"
  },
  "files": [
    "dist",
    "bin"
  ]
}
